<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  INFRASTRUCTURE SUITE — framework self-checks (no feature coverage)
  Run: mvn test -Pinfrastructure
-->
<suite name="Crust and Q Infrastructure Suite"
       parallel="methods"
       thread-count="3"
       data-provider-thread-count="1"
       verbose="1">

    <listeners>
        <listener class-name="com.crustq.listeners.TestListener"/>
    </listeners>

    <test name="Framework Infrastructure">
        <classes>
            <class name="com.crustq.tests.infrastructure.BaseLifecycleTest"/>
            <class name="com.crustq.tests.infrastructure.FactoryWiringTest"/>
            <class name="com.crustq.tests.infrastructure.FrameworkSmokeTest"/>
            <class name="com.crustq.tests.infrastructure.UtilsWiringTest"/>
            <class name="com.crustq.tests.infrastructure.MultiDriverBaseWiringTest"/>
        </classes>
    </test>
</suite>
