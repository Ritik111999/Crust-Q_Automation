<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  PWA-ONLY SUITE (Selenium / Chrome) — parallel methods, up to 6 browsers.
  Run: mvn test
  Run: mvn test -Ppwa
-->
<suite name="Crust and Q PWA Suite"
       parallel="methods"
       thread-count="6"
       data-provider-thread-count="1"
       verbose="1">

    <listeners>
        <listener class-name="com.crustq.listeners.TestListener"/>
    </listeners>

    <test name="PWA Auth Login">
        <classes>
            <class name="com.crustq.tests.pwa_only.user.UserPwaLoginTest"/>
            <class name="com.crustq.tests.pwa_only.user.UserProfileTest"/>
            <class name="com.crustq.tests.pwa_only.user.UserOrderCheckoutTest"/>
            <class name="com.crustq.tests.pwa_only.driver.DriverPwaLoginTest"/>
            <class name="com.crustq.tests.pwa_only.auth.PwaLoginNegativeTest"/>
        </classes>
    </test>
</suite>
