<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  Order checkout E2E — sequential (single browser session per test method).
  Run: mvn test -Ppwa -DsuiteXmlFile=src/test/resources/testng-order-checkout.xml
-->
<suite name="Crust and Q Order Checkout Suite"
       parallel="false"
       verbose="1">

    <listeners>
        <listener class-name="com.crustq.listeners.TestListener"/>
    </listeners>

    <test name="User Order Checkout">
        <classes>
            <class name="com.crustq.tests.pwa_only.user.UserOrderCheckoutTest"/>
        </classes>
    </test>
</suite>
