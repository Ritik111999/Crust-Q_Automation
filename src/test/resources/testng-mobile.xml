<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  MOBILE-ONLY SUITE (Appium — Android / iOS)
  Run: mvn test -Pmobile -Dplatform.active=android
  Feature tests under com.crustq.tests.mobile_only will be added later.
-->
<suite name="Crust and Q Mobile Suite"
       parallel="methods"
       thread-count="2"
       verbose="1">

    <listeners>
        <listener class-name="com.crustq.listeners.TestListener"/>
    </listeners>

    <test name="Mobile Bootstrap">
        <classes>
            <class name="com.crustq.tests.infrastructure.FrameworkSmokeTest"/>
        </classes>
    </test>
</suite>
