<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Crust and Q PWA CI Suite"
       parallel="methods"
       thread-count="3"
       data-provider-thread-count="2"
       verbose="1">

    <listeners>
        <listener class-name="com.crustq.listeners.TestListener"/>
    </listeners>

    <test name="Framework Smoke CI">
        <classes>
            <class name="com.crustq.tests.FrameworkSmokeTest"/>
        </classes>
    </test>
</suite>
