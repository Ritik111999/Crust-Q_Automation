<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  CROSS-FUNCTIONAL SUITE (PWA + Mobile in same flow)
  Run: mvn test -Pcross-functional
  E2E business flows under com.crustq.tests.cross_functional will be added in Step 5.
-->
<suite name="Crust and Q Cross-Functional Suite"
       parallel="false"
       verbose="1">

    <listeners>
        <listener class-name="com.crustq.listeners.TestListener"/>
    </listeners>

    <test name="Cross-Functional Bootstrap">
        <classes>
            <class name="com.crustq.tests.infrastructure.FrameworkSmokeTest"/>
        </classes>
    </test>
</suite>
